# ================================
# 水晶ERP系统环境配置文件
# 请复制此文件为 .env 并填入实际配置值
# ================================

# 服务器配置
# API服务端口，默认3001
PORT=3001
# 运行环境：development | production
NODE_ENV=development
# 前端应用地址，用于CORS配置
FRONTEND_URL=http://localhost:5173

# JWT配置
# 重要：生产环境必须使用强密钥！
# 可使用命令生成：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-key-here-change-in-production

# MySQL数据库配置
# 数据库主机地址（生产环境建议使用localhost）
DB_HOST=localhost
# 数据库端口
DB_PORT=3306
# 数据库用户名
DB_USER=your-db-user
# 数据库密码（请使用强密码）
DB_PASSWORD=your-db-password
# 数据库名称
DB_NAME=shuijing_erp

# 阿里云OSS配置（可选，用于文件存储）
# OSS区域
ALI_OSS_REGION=oss-cn-hangzhou
# OSS访问密钥ID
ALI_OSS_ACCESS_KEY_ID=your-access-key-id
# OSS访问密钥Secret
ALI_OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS存储桶名称
ALI_OSS_BUCKET=your-bucket-name

# 文件上传配置
# 单个文件最大大小（字节），默认5MB
UPLOAD_MAX_SIZE=5242880
# 最大文件数量
UPLOAD_MAX_FILES=10

# ================================
# 安全提示：
# 1. 生产环境必须修改JWT_SECRET为随机强密钥
# 2. 数据库密码应使用复杂密码
# 3. 不要将此文件提交到版本控制系统
# 4. 定期更换敏感配置信息
# ================================